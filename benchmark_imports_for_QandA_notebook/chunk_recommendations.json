  "_usage_example": {
    "description": "Paste this helper into your notebook to auto-select chunk config from duration + whisper model",
    "python_snippet": "import json\n\nwith open('chunk_recommendations.json') as f:\n    CHUNK_REC = json.load(f)\n\ndef get_chunk_config(duration_sec: int, whisper_key: str) -> dict:\n    \"\"\"\n    Returns optimal chunk_size, overlap and recommended_llm.\n    whisper_key: one of 'tiny','base','small','medium','large-v3','api'\n    \"\"\"\n    for bucket, b in CHUNK_REC['_buckets'].items():\n        if b['min_sec'] <= duration_sec < b['max_sec']:\n            return CHUNK_REC[whisper_key][bucket]\n    return CHUNK_REC[whisper_key]['long_video']  # safety fallback\n\n# --- Example: 5-min video (~300s), whisper-small ---\ncfg = get_chunk_config(300, 'small')\n# cfg = {'chunk_size': 150, 'overlap': 25, 'mrr': 0.95, 'recommended_llm': 'gpt-4o-mini', ...}\nprint(cfg['chunk_size'], cfg['overlap'], cfg['recommended_llm'])"
  }
